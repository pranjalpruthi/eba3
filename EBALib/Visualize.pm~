package MyLib::Visualize;

use strict;
use warnings;
#use Term::ANSIColor;

use Exporter;

our @EXPORT_OK = "visualizeFile";

sub visualizeFile {
my $path=shift;
my $dir="$path/EBA_OutFiles";
MyMod::Messages::viz();

		 opendir(DIR, $dir) or die $!;
   		 while (my $file = readdir(DIR)) {
        		# We only want files
        		next unless (-f "$dir/$file");
        		# Use a regular expression to find files ending in .txt
        		next unless ($file =~ m/\.eba2$/); 
			my @new_file=split(/_/, $file);
				if ($new_file[0] ne "") { 
					my $InFileName= "$path/EBA_OutFiles/$file";
					my $OutFileName= "$path/VIZ_EHFiles/$new_file[0]_viz_table.viz";
					createVisualize ($InFileName, $OutFileName);
       					# system ("perl" ,"visualize_table.pl","$path/EBA_OutFiles/$file","$path/VIZ_EHFiles/$new_file[0]_viz_table.viz");
					# if ( $? == -1 ){ print "command failed: $!\n";}
				}				
		  	}
		closedir(DIR);
}


sub createVisualize {

my ($InFile, $OutFile)= @_;

#!/usr/bin/perl
use strict;
#use warnings;

#this script is to generate a file that will be convenient to visualize the table data in EH

open INFILE,  $InFile or die MyMod::Messages::failOp($InFile);
open OUTFILE, ">" , $OutFile or die MyMod::Messages::failOp($OutFile);

$|++;

$/ = "\n";

while  (<INFILE>) {
my $line = $_;
next if $line=~m/^Species/;
chomp $line;
my @tmp=split /\t/, $line;
	for (@tmp) { s/^\s+//; s/\s+$//;}
	my @cor=split /\-\-/ , $tmp[2];  ## !!!
	my $count;
		for (my $aa=4;$#tmp+1>$aa;$aa++) {
		my $v=$tmp[$aa];
			if ( $v ne "0") {$count++;}
		}
print OUTFILE "$tmp[0]\t$tmp[1]\t$count\t$cor[0]\t$cor[1]\n";
$count=0;
}
close OUTFILE or die MyMod::Messages::failCl("outfile");
close INFILE or die MyMod::Messages::failCl("infile");
}

1;
