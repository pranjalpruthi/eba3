sub compare_all {  
@all_data=""; @val1="";@val2="";$j1=0;$j2=0;
	for (@_)  { s/\s+$//; }#replace one or more spaces at the end of it
	foreach (@_)
		{
		next if $_==0;
		next if $_ == "Breakpoint";
		next if $_ == "Gap";
		chomp ($_);
	#	next if $_== "";
		push (@all_data,$_);
		}
#	@all_data=clean_array(@all_data);
       # print "@all_data\n";
	for (@all_data)  { s/\s+$//; }#replace one or more spaces at the end of it
	
	if ($#all_data>1) {
	
	foreach $f(@all_data)
		{
		next if (!$f);
		@val1=split /\--/, $f; ##!!!!
		#print "$val1[0]\n";
		#return "$val1[1]\n";
	#	print OUTFILE "$f\n";
	foreach $c(@all_data)
			{
			@val2=split /\--/, $c;  # !!!!!!
			next if (!$c);	
		#	print OUTFILE "$c\n";
			next if ($val1[0]==$val2[0] and $val1[1]==$val2[1]);
			my $OverRes = MyLib::CommonSubs::checkCorOverlaps ($val1[0],$val1[1],$val2[0],$val2[1]);
			if ($OverRes){$j1++;} else {$j2++;}
			}
		
		}
		}
	else
		{
	#	return $j=1;
		}
		  	
return $j2;
undef @all_data;
 }
		 

