package MyLib::BreaksScoring2;
#use Term::ANSIColor;
use Exporter;

our @EXPORT_OK = "breakpointScoring2";

## This EBRs scoring approach are old one

sub breakpointScoring2 {
my $path=shift;
my $dir="$path/EBA_OutFiles";
MyLib::Messages::callProb2();

		 opendir(DIR, $dir) or die $!;
   		 while (my $file = readdir(DIR)) {
        		# We only want files
        		next unless (-f "$dir/$file");
        		# Use a regular expression to find files ending in .txt
        		next unless ($file =~ m/\.eba3$/); 
			my @new_file=split(/_/, $file);
				if ($new_file[0] ne "") { 
					my $InFileName="$path/EBA_OutFiles/$file";
					my $OutFileName="$path/EBA_OutFiles/$new_file[1]_table_scored.eba4";
					scoreIt($InFileName, $OutFileName);
       			 		#system ("perl" ,"brk_score.pl", "$path/EBA_OutFiles/$file", "$path/EBA_OutFiles/$new_file[1]_table_scored.eba4");
					#if ( $? == -1 ){ print "command failed: $!\n";}
				}				
		  }
closedir(DIR);
}



sub scoreIt {

my ($InFile, $OutFile)=@_;

#!/usr/bin/perl
#use strict;
#use warnings;

open INFILE,  $InFile or die MyLib::Messages::failOp($InFile);
open OUTFILE, ">" , $OutFile or die MyLib::Messages::failOp($OutFile);

$/ = "\n";
$i=0;

open SPSFILE, "sps.txt" or die $!;
while (<SPSFILE>) { $l=MyLib::CommonSubs::trim($_); chomp $l; @t=split /,/, lc($l); $t_len = scalar (@t); }
$ts=join("\t", @t); 
close SPSFILE or die MyLib::Messages::failCl("sps.txt");

print OUTFILE  "Species\tChromosome\tBrk_Point\tBreakpoint_Decision\t$ts\t\tScore\n";

while (<INFILE>) {
$line=$_;
@tmp=split /\t/, $line;
chomp $line;
	if ($line=~ m/^Species/) {	
		foreach $xx(0..@tmp) {
		push (@name,$tmp[$xx]);
		}
	next;
	}
#push (@values,$line);
for (@tmp) { s/^\s+//; s/\s+$//; }#replace one or more spaces
#print $#tmp;
for ($a=1;$a<=$#tmp;$a++) {
	$decision=$tmp[3];
	chomp ($decision);
		if ($a>=4){
			#print OUTFILE "$tmp[$a]";
			$total=(1/($#tmp-4));
	
	 			if ($tmp[$a] ne 0) {
				@jai=split/\,/, "$tmp[$a]"; for (@jai) { s/^\s+//; s/\s+$//; }#replace one or more spaces
					foreach (@jai) {
						@bb=split /\=/,$_; 	for (@bb) { s/^\s+//; s/\s+$//; }#replace one or more spaces
						{
						foreach (@bb){
							push (@all_values,$_);	
							}
						}	
					}
				@v=split /\=/, "$tmp[$a]";
				if ($v[1] eq "Gap"){
					$i++; 
					}
					push @all, $tmp[$a];
		
				}
		}
	}
for (@all_values)  { s/^\s+//; s/\s+$//; }#replace one or more spaces
$brk_num=$#all-$i;
#print OUTFILE "$brk_num\t$i\t$#all\n";

	if($i>=1){
		$score1=($brk_num*$total);
		$score2=($total*$i)/2;
		$score=$score1+$score2;
		#print "$score -----$score1=($#all*$total)::::::::::::$score2=($total*$i)/2\n";
	}
	else {
		#$score=($#all)/($#tmp-4) ; ; 
		$score=$total*$brk_num;
	}

if($decision eq "Gap"){
	$dem=compare_all(@all_values);# print "$dem\n";	
	#$score += $_ for @gap_score;
	#$score=($dem/$#all_data)*$total;
	if ($dem==0) {$score=$#all*$total;}
	else { $score=($#all_data/$dem)*$total; }
	#print "  $score=($#all_data/$dem)*$total---------$score\t @all_data\n";
	}

	foreach(@tmp){
	print OUTFILE "$_\t";   
		}

	print OUTFILE "$score";

print OUTFILE "\n";
undef @all; $i=0; $j=0;$score=0; undef @gap_score; undef @all_values;	undef @name;
}
close OUTFILE or die MyLib::Messages::failCl("file");
close INFILE or die MyLib::Messages::failCl("file");
} ## Subroutine close here 


