package MyLib::Safai;

use strict;
use warnings;
use File::Path;
use File::Find;
#use Term::ANSIColor;

use Exporter;

our @EXPORT_OK = "cleanUp";

sub cleanUp {
my $root_directory=shift;
#print "Cleaning all the intermediate files\n";
finddepth(\&wanted, $_) for $root_directory;

sub wanted {
my $directory_to_delete="EBA_OutFiles";
	if ( -d ) { # For directory ... -f for files
		#print "$_\n";
	    if ($_ eq $directory_to_delete) { rmtree ( "$_" ) or die (MyLib::Messages::noDel($_)); }

        }
    }
}

1;


